<?xml version="1.0" encoding="utf-8"?>
<!--
    Tắt hoàn toàn Android cloud backup cho file database và preferences.
    Dữ liệu nhạy cảm không được sync lên Google cloud.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="aemeath.db" />
        <exclude domain="sharedpref" path="aemeath_prefs.xml" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="aemeath.db" />
        <exclude domain="sharedpref" path="aemeath_prefs.xml" />
    </device-transfer>
</data-extraction-rules>